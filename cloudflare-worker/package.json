{
  "name": "stephenson-stump-worker",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create stephenson-stump-db",
    "db:migrate:local": "wrangler d1 execute stephenson-stump-db --local --file=src/db/migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute stephenson-stump-db --remote --file=src/db/migrations/0001_init.sql"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.10"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250516.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.16.0"
  }
}
